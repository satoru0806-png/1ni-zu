{
  "name": "speaknote-mac",
  "productName": "SpeakNote",
  "version": "1.0.0",
  "description": "Mac用音声入力 → AI整形アプリ",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "postinstall": "electron-rebuild -f -v 41.1.1",
    "rebuild": "electron-rebuild -f -v 41.1.1",
    "build": "npm run rebuild && vite build",
    "start": "electron-forge start",
    "package": "npm run rebuild && electron-forge package",
    "package:win": "npm run rebuild && electron-forge package --platform=win32 --arch=x64",
    "make": "npm run rebuild && electron-forge make",
    "make:win": "npm run rebuild && electron-forge make --platform=win32 --arch=x64",
    "publish": "electron-forge publish",
    "lint": "eslint --ext .ts,.tsx .",
    "dist": "npm run rebuild && electron-builder"
  },
  "keywords": [],
  "author": "owner",
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.0.3",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.4.27",
    "electron": "41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.5.4",
    "vite": "^5.4.21"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "electron-store": "^11.0.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "uiohook-napi": "^1.5.5"
  }
}
